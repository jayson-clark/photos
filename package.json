{
    "name": "photos-clone",
    "version": "1.0.0",
    "private": true,
    "workspaces": [
        "packages/*",
        "apps/*"
    ],
    "scripts": {
        "dev": "npm-run-all --parallel dev:*",
        "dev:backend": "npm run dev --workspace=@photos/backend",
        "dev:frontend": "npm run dev --workspace=@photos/frontend",
        "build": "npm run build --workspaces",
        "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,css,scss,html,mdx,tsx}\"",
        "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,css,scss,html,mdx,tsx}\"",
        "clean": "rm -rf node_modules packages/*/node_modules apps/*/node_modules packages/*/dist apps/*/dist"
    },
    "devDependencies": {
        "npm-run-all": "^4.1.5",
        "typescript": "^5.3.3",
        "prettier": "^2.8.8"
    }
}
